{
  "compilerOptions": {
    "target": "ES2019",
    "module": "CommonJS",
    "lib": ["ES2019"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "jsx": "react",
    "jsxFactory": "ForgeUI.createElement"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
